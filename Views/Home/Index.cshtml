@{
    ViewData["Title"] = "خانه";
}

<div class="text-center py-5">
    <h1 class="display-5 fw-bold">به سامانه تیکت پشتیبانی خوش آمدید</h1>
    <p class="lead text-muted">برای ثبت درخواست پشتیبانی، ابتدا ثبت‌نام یا وارد حساب کاربری خود شوید.</p>
    @if (User.Identity == null || !User.Identity.IsAuthenticated)
    {
        <a class="btn btn-primary btn-lg me-2" asp-controller="Account" asp-action="Register">ثبت‌نام</a>
        <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Login">ورود</a>
    }
    else
    {
        <a class="btn btn-primary btn-lg" asp-controller="Tickets" asp-action="Index">مشاهده تیکت‌ها</a>
    }
</div>
