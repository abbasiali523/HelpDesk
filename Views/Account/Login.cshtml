@model HelpDesk.Controllers.LoginViewModel
@{
    ViewData["Title"] = "ورود";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">ورود به حساب کاربری</h2>
        <div class="alert alert-info">
            کاربر پیش‌فرض مدیر سیستم: <strong>admin</strong> / رمز عبور: <strong>admin</strong>
        </div>
        <div asp-validation-summary="All" class="text-danger"></div>
        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary w-100">ورود</button>
        </form>
        <p class="mt-3">حساب کاربری ندارید؟ <a asp-controller="Account" asp-action="Register">ثبت‌نام کنید</a></p>
    </div>
</div>
