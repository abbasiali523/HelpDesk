<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>سامانه تیکت پشتیبانی</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">سامانه هلپ‌دسک</a>
            <div class="d-flex gap-2">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Tickets" asp-action="Index">تیکت‌های من</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="Tickets" asp-action="Create">ثبت تیکت جدید</a>
                    <span class="navbar-text text-light">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-danger btn-sm">خروج</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">ورود</a>
                    <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">ثبت‌نام</a>
                }
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
